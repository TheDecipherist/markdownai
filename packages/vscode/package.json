{
  "name": "markdownai",
  "displayName": "MarkdownAI",
  "description": "Syntax highlighting, snippets, and autocomplete for MarkdownAI documents",
  "version": "0.0.9",
  "publisher": "markdownai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "markdownai",
    "markdown",
    "directives",
    "live-documents",
    "syntax-highlighting",
    "autocomplete"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheDecipherist/markdownai.git"
  },
  "bugs": {
    "url": "https://github.com/TheDecipherist/markdownai/issues"
  },
  "homepage": "https://github.com/TheDecipherist/markdownai/tree/main/packages/vscode#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "markdownai",
        "aliases": [
          "MarkdownAI",
          "markdownai"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "markdownai",
        "scopeName": "text.markdownai",
        "path": "./syntaxes/markdownai.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.markdown": "markdown",
          "meta.embedded.block.yaml": "yaml"
        }
      }
    ],
    "snippets": [
      {
        "language": "markdownai",
        "path": "./snippets/markdownai.code-snippets"
      }
    ],
    "configuration": {
      "title": "MarkdownAI",
      "properties": {
        "markdownai.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable MarkdownAI diagnostics (error squiggles and warnings)."
        },
        "markdownai.diagnostics.warnUndefinedMacros": {
          "type": "boolean",
          "default": true,
          "description": "Show warnings when @call references a macro that is not defined in the document or stdlib."
        },
        "markdownai.stdlibPath": {
          "type": "string",
          "default": "packages/engine/src/stdlib.md",
          "description": "Relative path from workspace root to the MarkdownAI stdlib macro definitions file."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
